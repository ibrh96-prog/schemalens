# Neon PostgreSQL connection string — this is SchemaLens's OWN database for metadata storage.
# Create a free database at https://neon.tech, then paste the connection string here.
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Optional — API server port (default: 8080)
PORT=8080

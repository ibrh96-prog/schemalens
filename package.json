{
  "name": "schemalens",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"pnpm --filter api-server dev\" \"pnpm --filter schemalens dev\"",
    "build": "pnpm --filter schemalens build && pnpm run build:api",
    "build:api": "esbuild artifacts/api-server/src/index.ts --bundle --platform=node --format=cjs --outfile=api/_bundle.cjs --external:pg-native",
    "db:generate": "drizzle-kit generate --config=lib/db/drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=lib/db/drizzle.config.ts",
    "db:seed": "tsx lib/db/seed/run-seed.ts"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "concurrently": "^8.2.2",
    "drizzle-kit": "^0.22.8",
    "esbuild": "^0.21.5",
    "tsx": "^4.15.0",
    "typescript": "^5.5.3"
  }
}

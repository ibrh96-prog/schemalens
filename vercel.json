{
  "buildCommand": "pnpm run build",
  "outputDirectory": "artifacts/schemalens/dist",
  "functions": {
    "api/index.ts": {
      "maxDuration": 30,
      "includeFiles": "api/_bundle.cjs"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.ts"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
